generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  ADMIN
  IT
  MANAGER
  STAFF
}

enum TicketStatus {
  WAITING
  CALLED
  SERVING
  COMPLETED
  NO_SHOW
  CANCELLED
  TRANSFERRED_OUT
}

enum ActorType {
  USER
  SYSTEM
  PATIENT_WHATSAPP
  PATIENT_PWA
  KIOSK
}

enum TemplateChannel {
  WHATSAPP
}

enum DeviceType {
  KIOSK
  TELLER_PC
  SIGNAGE_PLAYER
  LED_ADAPTER
}

enum IntegrationProvider {
  ULTRAMESSAGE
}

model Hospital {
  id        String   @id @default(uuid())
  nameAr    String
  nameEn    String
  address   String?
  email     String?
  website   String?
  logoPath  String?
  timezone  String   @default("Asia/Riyadh")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments        Department[]
  stations           CounterStation[]
  users              User[]
  priorityCategories PriorityCategory[]
  tickets            Ticket[]
  templates          MessageTemplate[]
  devices            Device[]
  integrations       IntegrationConfig[]
  auditLogs          AuditLog[]
}

model Department {
  id         String   @id @default(uuid())
  hospitalId String
  nameAr     String
  nameEn     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hospital        Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  services        Service[]
  roleAssignments RoleAssignment[]
  devices         Device[]
  tickets         Ticket[]

  @@index([hospitalId])
  @@unique([hospitalId, nameEn])
}

model Service {
  id                   String   @id @default(uuid())
  departmentId         String
  nameAr               String
  nameEn               String
  ticketPrefix         String
  /// Optional, statically configured average wait time (in minutes) for this service.
 /// When null, no preconfigured wait estimate exists; consumers should treat wait
 /// time estimates as unavailable or derive them dynamically from live queue data.
 estimatedWaitMinutes Int?
 /// Number of people ahead of a ticket at which "nearing turn" notifications may be triggered.
 /// This applies regardless of whether `estimatedWaitMinutes` is configured.
 nearingTurnThreshold Int      @default(3)
 dailyResetEnabled    Boolean  @default(true)
 isActive             Boolean  @default(true)
 createdAt            DateTime @default(now())
 updatedAt            DateTime @updatedAt

 department Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
 stations   CounterStation[]
 tickets    Ticket[]

 @@index([departmentId])
 @@unique([departmentId, ticketPrefix])
 @@unique([departmentId, nameEn])
}

model CounterStation {
  id          String   @id @default(uuid())
  hospitalId  String
  serviceId   String
  counterCode String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  calledTickets Ticket[]      @relation("CalledStation")
  ticketEvents  TicketEvent[]
  devices       Device[]

  @@index([hospitalId])
  @@index([serviceId])
  @@unique([hospitalId, counterCode])
}

model User {
  id                  String   @id @default(uuid())
  hospitalId          String
  email               String
  passwordHash        String
  isActive            Boolean  @default(true)
  mustChangePassword  Boolean  @default(false)
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  avatarPath          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  hospital        Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  roleAssignments RoleAssignment[]
  ticketLocks     Ticket[]         @relation("TicketLockOwner")
  ticketEvents    TicketEvent[]
  auditLogs       AuditLog[]

  @@index([hospitalId])
  @@unique([hospitalId, email])
}

model RoleAssignment {
  id           String   @id @default(uuid())
  userId       String
  role         AppRole
  departmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([departmentId])
  @@unique([userId, role, departmentId])
}

model PriorityCategory {
  id         String   @id @default(uuid())
  hospitalId String
  code       String
  nameAr     String
  nameEn     String
  weight     Int
  isSystem   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  tickets  Ticket[]

  @@index([hospitalId])
  @@unique([hospitalId, code])
  @@unique([hospitalId, weight])
}

model Ticket {
  id                    String      @id @default(uuid())
  hospitalId            String
  departmentId          String
  serviceId             String
  // ticketDate represents the hospital-local calendar date bucket for this ticket.
  // It MUST be stored as a canonical UTC timestamp corresponding to that local day
  // (e.g. the start-of-day in the hospital's timezone as defined in Hospital.timezone).
  // Application code is responsible for converting between the hospital's local date
  // and this UTC bucket when creating tickets and when querying by ticketDate, so that
  // per-day sequencing and uniqueness constraints remain correct across time zones.
  ticketDate            DateTime
  sequenceNumber        Int
  ticketNumber          String
  phoneNumber           String
  priorityCategoryId    String
  /// Ticket lifecycle state. Typical flow:
  /// WAITING -> CALLED (when the ticket is first announced at a counter),
  /// CALLED -> SERVING (when the staff member explicitly starts serving),
  /// SERVING -> COMPLETED or CANCELLED.
  status                TicketStatus @default(WAITING)
  /// Timestamp when the ticket was first called to a counter.
  /// Set when status transitions to CALLED.
  calledAt              DateTime?
  /// Timestamp when serving actually started at the counter.
  /// Set by an explicit "start serving" action when status transitions from CALLED to SERVING;
  /// not automatically derived from calledAt.
  servingStartedAt      DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  calledCounterStationId String?
  lockedByUserId        String?
  lockedUntil           DateTime?
  originTicketId        String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  hospital         Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  department       Department       @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  service          Service          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  priorityCategory PriorityCategory @relation(fields: [priorityCategoryId], references: [id], onDelete: Restrict)
  calledStation    CounterStation?  @relation("CalledStation", fields: [calledCounterStationId], references: [id], onDelete: SetNull)
  lockOwner        User?            @relation("TicketLockOwner", fields: [lockedByUserId], references: [id], onDelete: SetNull)
  originTicket     Ticket?          @relation("TicketTransferChain", fields: [originTicketId], references: [id], onDelete: SetNull)
  transferredTo    Ticket[]         @relation("TicketTransferChain")
  events           TicketEvent[]

  // General indexes
  @@index([hospitalId])
  @@index([departmentId])
  @@index([serviceId])
  @@index([phoneNumber])
  @@index([status])
  @@index([priorityCategoryId, createdAt])

  // Business rule: At most one *active* ticket per (phoneNumber, serviceId).
  // Active tickets are those with status in {WAITING, CALLED, SERVING}.
  // This cannot be expressed as a simple unique constraint in Prisma because it
  // depends on the status field (i.e. it would require a partial unique index).
  // The application layer is responsible for enforcing this invariant by checking
  // for existing active tickets before creating a new one, typically using this
  // composite index for efficient lookups:
  @@index([phoneNumber, serviceId, status])

  // Ticket numbering uniqueness per service and date
  @@unique([serviceId, ticketDate, sequenceNumber])
  @@unique([serviceId, ticketDate, ticketNumber])
}

model TicketEvent {
  id          String   @id @default(uuid())
  ticketId    String
  eventType   String
  actorType   ActorType
  actorUserId String?
  stationId   String?
  payload     Json?
  occurredAt  DateTime @default(now())

  ticket    Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorUser User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  station   CounterStation? @relation(fields: [stationId], references: [id], onDelete: SetNull)

  @@index([ticketId, occurredAt])
  @@index([eventType, occurredAt])
}

model MessageTemplate {
  id         String          @id @default(uuid())
  hospitalId String
  channel    TemplateChannel
  eventType  String
  language   String
  content    String
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@unique([hospitalId, channel, eventType, language])
}

model Device {
  id                       String    @id @default(uuid())
  hospitalId               String
  deviceId                 String    @unique
  deviceType               DeviceType
  displayName              String?
  assignedDepartmentId     String?
  assignedCounterStationId String?   @unique
  config                   Json?
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  hospital      Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  department    Department?    @relation(fields: [assignedDepartmentId], references: [id], onDelete: SetNull)
  counterStation CounterStation? @relation(fields: [assignedCounterStationId], references: [id], onDelete: SetNull)

  @@index([hospitalId])
  @@index([assignedDepartmentId])
}

model IntegrationConfig {
  id         String              @id @default(uuid())
  hospitalId String
  provider   IntegrationProvider
  config     Json?
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@unique([hospitalId, provider])
}

model AuditLog {
  id          String   @id @default(uuid())
  hospitalId  String
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  occurredAt  DateTime @default(now())

  hospital  Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  actorUser User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([hospitalId, occurredAt])
  @@index([entityType, entityId])
}
