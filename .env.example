DATABASE_URL=postgresql://smart_queue:smart_queue@localhost:5432/smart_queue

# SECURITY: These values are intentionally insecure placeholders.
# You MUST replace both secrets with strong, unique values before any non-local deployment.
JWT_ACCESS_TOKEN_EXPIRES_IN_SECONDS=900
JWT_ACCESS_TOKEN_SECRET=INSECURE-CHANGE-ME-IN-PRODUCTION-ACCESS
JWT_REFRESH_TOKEN_EXPIRES_IN_SECONDS=2592000
JWT_REFRESH_TOKEN_SECRET=INSECURE-CHANGE-ME-IN-PRODUCTION-REFRESH
NODE_ENV=development
# Use '*' only for local development/testing.
# In production, set a comma-separated allowlist (for example: https://admin.local,https://teller.local).
# For LAN multi-PC testing, either keep '*' or list each client origin:
#   REALTIME_CORS_ALLOWED_ORIGINS=http://192.168.1.101:5173,http://192.168.1.102:5173
# This setting now controls CORS for BOTH the HTTP API and the realtime WebSocket server.
REALTIME_CORS_ALLOWED_ORIGINS=*

PORT=3000
POSTGRES_DB=smart_queue
POSTGRES_PASSWORD=smart_queue
POSTGRES_PORT=5432
POSTGRES_USER=smart_queue
REDIS_URL=redis://localhost:6379
# Async jobs worker parallelism (default baseline is 1 for conservative processing).
ASYNC_JOBS_WORKER_CONCURRENCY=1
# Number of completed jobs to retain in BullMQ for debugging/observability.
ASYNC_JOBS_RETAIN_COMPLETED_JOBS=1000
# Number of failed jobs to retain in BullMQ for debugging/observability.
ASYNC_JOBS_RETAIN_FAILED_JOBS=1000
