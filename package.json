{
  "name": "smart-queue-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Smart Queue backend API service",
  "scripts": {
    "dev": "jiti src/dev.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "npm run test:queue && npm run test:auth",
    "test:queue": "node ./scripts/run-jiti-tests.mjs src/queue-engine/__tests__/selector.test.ts src/queue-engine/__tests__/state-machine.test.ts",
    "test:queue:win": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-queue-engine-tests.ps1",
    "test:auth": "node ./scripts/run-jiti-tests.mjs src/auth/__tests__/password.test.ts src/auth/__tests__/tokens.test.ts src/auth/__tests__/login.test.ts src/auth/__tests__/refresh.test.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "dotenv": "^17.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "jiti": "^2.4.2",
    "prisma": "^5.22.0",
    "typescript": "^5.7.2"
  }
}
